{
  "manifest_version": 2,
  "name": "AuditLogger",
  "version": "1.0",
  "description": "Logs session events for auditing.",
  "permissions": ["<all_urls>", "webRequest", "webRequestBlocking", "cookies"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "auditor@orchestrator.local"
    }
  }
}
